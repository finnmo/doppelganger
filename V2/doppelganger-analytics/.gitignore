secrets.enc.json
.master-key
**/.env.local
**/credentials.json

# Secrets / credentials (never commit — keys live under ~/.doppelgaenger-analytics/)
**/secrets.enc.json
**/.master-key
.env
.env.*
!.env.example

# OS files
.DS_Store
